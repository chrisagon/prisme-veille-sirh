# OPENROUTER_API_KEY: Required for Perplexity Sonar Deep Research API calls via OpenRouter.
# Obtain your key at https://openrouter.ai/keys
OPENROUTER_API_KEY="MY_OPENROUTER_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SMTP_USER and SMTP_PASS: Configuration for sending emails via OVH or other SMTP providers
SMTP_USER=""
SMTP_PASS=""

# Worker de scan périodique (story 2-1)
# Credentials Firebase Admin (une seule des deux)
# GOOGLE_APPLICATION_CREDENTIALS="/path/to/serviceAccountKey.json"
# FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}'
SCAN_USER_AGENT="PRISME-Bot/1.0"
SCAN_TIMEOUT_MS=3500
SCAN_RATE_LIMIT_MS=1000

# -----------------------------------------------------------------------------
# Admin gate — Story 2-4 (veille automatique)
# -----------------------------------------------------------------------------
# Token Bearer requis pour les endpoints admin de la veille :
#   - POST /api/veille/admin/purge-expired
# Vérification serveur : crypto.timingSafeEqual (constant-time, anti-timing-attack).
# Si ABSENT : endpoints en fail-closed (renvoient 401 `admin_token_unconfigured`).
# L'UI admin doit passer `Authorization: Bearer <VEILLE_ADMIN_TOKEN>`.
#
# Génération recommandée (32 octets = 64 hex chars) :
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
VEILLE_ADMIN_TOKEN=""
